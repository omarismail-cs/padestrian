# OpenRouteService — walking isochrones (build-zones)
ORS_API_KEY=

# Mapbox — geocoding (scrape-listings, check-an-address)
MAPBOX_ACCESS_TOKEN=

# Next.js client (same Mapbox token)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Supabase — listing catalog (Phase 1)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# listings backend: supabase | file (auto-detects supabase when URL + key are set)
LISTINGS_BACKEND=supabase

# Optional: set to false to disable POST /api/import-kijiji
# KIJIJI_IMPORT_ENABLED=false
